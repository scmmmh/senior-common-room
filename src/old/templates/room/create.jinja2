{% extends 'scr:templates/layout.jinja2' %}

{% block title %}Create a new Room{% endblock title %}

{% block body %}
{% import 'scr:templates/macros/forms.jinja2' as form with context %}
<div class="grid-container">
  <main class="grid-x">
    <form class="cell small-12 medium-8 medium-offset-2 large-6 large-offset-3" action="{{ 'room.create'|route_url() }}" method="post">
      <h1>Create a new Room</h1>
      <input type="hidden" name="csrf_token" value="{{ get_csrf_token() }}"/>
      {{ form.field('name', 'text', 'Room Name') }}
      <div class="button-list">
        <a href="{{ 'root'|route_url() }}" class="button secondary">Don't create</a>
        <button class="button">Create</button>
      </div>
    </form>
  </main>
</div>
{% endblock body %}
