{% extends 'scr:templates/layout.jinja2' %}

{% block title %}Edit Room {{ room.name }}{% endblock title %}

{% block body %}
{% import 'scr:templates/macros/forms.jinja2' as form with context %}
<div class="grid-container">
  <main class="grid-x">
    <form class="cell small-12 medium-8 medium-offset-2 large-6 large-offset-3" action="{{ 'room.edit'|route_url(rid=room.id) }}" method="post">
      <h1>Edit Room {{ room.name }}</h1>
      {{ errors }}
      <input type="hidden" name="csrf_token" value="{{ get_csrf_token() }}"/>
      {{ form.field('name', 'text', 'Room Name', {'value': room.name}) }}
      <ul class="no-bullet">
        {% for user in users %}
          <li class="grid-x grid-padding-x">
            <span class="cell small-12 medium-auto">{{ user.user.attributes.name }}</span>
            <span class="cell small-6 medium-shrink">
              {% if user.host %}
                {% if user.user.id == request.current_user.id %}
                  {{ form.field('host', 'checkbox', 'Host', {'value': user.user.id, 'checked': 'checked', 'disabled': 'disabled'}) }}
                {% else %}
                  {{ form.field('host', 'checkbox', 'Host', {'value': user.user.id, 'checked': 'checked'}) }}
                {% endif %}
              {% else %}
                {% if user.user.id == request.current_user.id %}
                  {{ form.field('host', 'checkbox', 'Host', {'value': user.user.id, 'disabled': 'disabled'}) }}
                {% else %}
                  {{ form.field('host', 'checkbox', 'Host', {'value': user.user.id}) }}
                {% endif %}
              {% endif %}
            </span>
            <span class="cell small-6 medium-shrink">
              {% if user.participant %}
                {% if user.user.id == request.current_user.id %}
                  {{ form.field('participant', 'checkbox', 'Participant', {'value': user.user.id, 'checked': 'checked', 'disabled': 'disabled'}) }}
                {% else %}
                  {{ form.field('participant', 'checkbox', 'Participant', {'value': user.user.id, 'checked': 'checked'}) }}
                {% endif %}
              {% else %}
                {% if user.user.id == request.current_user.id %}
                  {{ form.field('participant', 'checkbox', 'Participant', {'value': user.user.id, 'disabled': 'disabled'}) }}
                {% else %}
                  {{ form.field('participant', 'checkbox', 'Participant', {'value': user.user.id}) }}
                {% endif %}
              {% endif %}
            </span>
          </li>
        {% endfor %}
      </ul>
      <div class="button-list">
        <a href="{{ 'root'|route_url() }}" class="button secondary">Don't update</a>
        <button class="button">Update</button>
      </div>
    </form>
  </main>
</div>
{% endblock body %}
