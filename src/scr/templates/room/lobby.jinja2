{% extends 'scr:templates/layout.jinja2' %}

{% block title %}{{ room.name }} - Lobby{% endblock title %}

{% block body %}
{% import 'scr:templates/macros/forms.jinja2' as form with context %}
<div class="grid-container">
  <main class="grid-x">
    <div class="cell small-12 medium-8 medium-offset-2 large-6 large-offset-3">
      <h1>{{ room.name }}</h1>
      <p>No host has arrived yet to unlock the door. Please wait here and you will automatically be invited into the room
        when a host has opened it.</p>
    </div>
  </main>
</div>
<script>
setTimeout(function() {
    window.location.reload();
}, 5000);
</script>
{% endblock body %}
