{% extends '../layout.jinja2' %}

{% block title %}Log in to the Senior Common Room{% endblock title %}

{% block body %}
{% import 'scr:templates/macros/forms.jinja2' as form with context %}
<div class="grid-container">
  <main class="grid-x">
    <form class="cell small-12 medium-8 medium-offset-2 large-6 large-offset-3" action="{{ request.route_url('user.login') }}" method="post">
      <h1>Log in</h1>
      <input type="hidden" name="redirect" value="{{ request.params.redirect }}"/>
      <input type="hidden" name="csrf_token" value="{{ get_csrf_token() }}"/>
      {{ form.field('email', 'email', 'E-Mail') }}
      {{ form.field('password', 'password', 'Password') }}
      <div class="button-list">
        <button class="button">Log in</button>
      </div>
    </form>
</div>
{% endblock body %}